  "packages": [
    {
      "registryType": "npm",
      "identifier": "@apex-coverage/cli",
      "version": "0.1.0",
      "transport": {
        "type": "stdio"
      },
      "packageArguments": ["mcp"],
      "environmentVariables": []
    },
    {
      "registryType": "pypi",
      "identifier": "apex-coverage",
      "version": "0.1.0",
      "transport": {
        "type": "stdio"
      },
      "packageArguments": ["mcp"],
      "environmentVariables": []
    }
  ],
  "repository": {
    "url": "https://github.com/allexdav2/apex",
    "source": "github"
  },
  "keywords": ["coverage", "security", "testing", "sast", "cwe", "sarif"]
}
